# Mẫu cấu hình Nginx reverse proxy cho DECOR CAR trên Hostinger VPS.
# Đặt tại: /etc/nginx/sites-available/decorcar  rồi tạo symlink sang sites-enabled.
# Nhớ thay decorcar.vn bằng tên miền thật.

server {
    listen 80;
    server_name decorcar.vn www.decorcar.vn;

    # Chuyển toàn bộ HTTP sang HTTPS sau khi cài SSL (Certbot).
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Phục vụ file tĩnh trực tiếp để giảm tải cho Node (tuỳ chọn).
    location /css/   { proxy_pass http://127.0.0.1:3000; }
    location /js/    { proxy_pass http://127.0.0.1:3000; }
    location /img/   { proxy_pass http://127.0.0.1:3000; }
    location /uploads/ { proxy_pass http://127.0.0.1:3000; }

    client_max_body_size 8M; # cho phép upload ảnh sản phẩm tới 8MB
}

# Sau khi domain trỏ về VPS, cài SSL miễn phí:
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d decorcar.vn -d www.decorcar.vn
