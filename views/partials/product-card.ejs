<%
  var _r = (typeof ratingFor === 'function') ? ratingFor(product.id) : { average: 0, count: 0 };
  var _stock = product.stock || 0;
  var _hasSecond = product.images && product.images.length > 1;
  var _hasOptions = product.options && product.options.length;
%>
<article class="card">
  <button type="button" class="card__wish" data-wish="<%= product.id %>" aria-label="Lưu vào yêu thích" aria-pressed="false">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 20s-7-4.35-9.5-8.5C1 8 2.5 5 5.5 5c2 0 3.2 1.2 4 2.3C10.3 6.2 11.5 5 13.5 5c3 0 4.5 3 3 6.5C19 15.65 12 20 12 20z"/></svg>
  </button>
  <a class="card__media frame" href="/san-pham/<%= product.slug %>">
    <img class="card__img card__img--front" src="<%= product.images[0] %>" alt="<%= product.name %>" loading="lazy" decoding="async" width="800" height="1000" />
    <% if (_hasSecond) { %>
      <img class="card__img card__img--back" data-src="<%= product.images[1] %>" alt="" aria-hidden="true" decoding="async" width="800" height="1000" />
    <% } %>
    <% if (product.compareAt && product.compareAt > product.price) { %>
      <span class="card__tag">Ưu đãi</span>
    <% } %>
    <% if (_stock === 0) { %>
      <span class="card__tag card__tag--out">Tạm hết</span>
    <% } else if (_stock <= 5) { %>
      <span class="card__tag card__tag--low">Sắp hết</span>
    <% } %>
  </a>
  <div class="card__body">
    <p class="card__eyebrow"><%= (categories || []).find(function(c){return c.slug===product.categorySlug}) ? (categories.find(function(c){return c.slug===product.categorySlug}).name) : '' %></p>
    <h3 class="card__title"><a href="/san-pham/<%= product.slug %>"><%= product.name %></a></h3>
    <div class="card__rating">
      <% if (_r.count > 0) { %>
        <span class="stars stars--sm" aria-hidden="true"><%= starString(_r.average) %></span>
        <span class="card__rating-num"><%= _r.average %></span>
        <span class="card__rating-count">(<%= _r.count %>)</span>
      <% } else { %>
        <span class="card__rating-none">Chưa có đánh giá</span>
      <% } %>
    </div>
    <div class="card__price">
      <span class="price"><%= formatVND(product.price) %></span>
      <% if (product.compareAt && product.compareAt > product.price) { %>
        <span class="price price--old"><%= formatVND(product.compareAt) %></span>
      <% } %>
    </div>
    <% if (_stock === 0) { %>
      <a href="/san-pham/<%= product.slug %>" class="btn btn--ghost btn--block">Liên hệ đặt hàng</a>
    <% } else if (_hasOptions) { %>
      <a href="/san-pham/<%= product.slug %>" class="btn btn--ghost btn--block">Chọn tuỳ chọn →</a>
    <% } else { %>
      <form action="/gio-hang/them" method="post" class="card__add">
        <input type="hidden" name="productId" value="<%= product.id %>" />
        <button type="submit" class="btn btn--ghost btn--block">Thêm vào giỏ</button>
      </form>
    <% } %>
  </div>
</article>
