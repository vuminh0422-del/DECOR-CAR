<header class="site-header" data-header>
  <div class="topbar">
    <div class="container topbar__row">
      <span class="topbar__msg">Giao hàng &amp; lắp đặt tận nơi · Tư vấn không gian miễn phí</span>
      <a class="topbar__hot" href="tel:<%= store.phone.replace(/\s/g,'') %>">Hotline: <%= store.phone %></a>
    </div>
  </div>

  <div class="container nav">
    <button class="nav__toggle" aria-label="Mở menu" aria-expanded="false" data-menu-toggle>
      <span></span><span></span><span></span>
    </button>

    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 40 40" width="34" height="34"><rect x="3" y="3" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M3 11 L3 3 L11 3 M37 11 L37 3 L29 3 M3 29 L3 37 L11 37 M37 29 L37 37 L29 37" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="20" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      </span>
      <span class="brand__name">DECOR&nbsp;CAR</span>
    </a>

    <nav class="nav__links" data-menu aria-label="Điều hướng chính">
      <a href="/cua-hang" class="<%= currentPath === '/cua-hang' ? 'is-active' : '' %>">Cửa hàng</a>
      <% categories.forEach(function(c){ %>
        <a href="/danh-muc/<%= c.slug %>" class="<%= currentPath === '/danh-muc/' + c.slug ? 'is-active' : '' %>"><%= c.name %></a>
      <% }) %>
      <a href="/blog" class="<%= currentPath.indexOf('/blog')===0 ? 'is-active' : '' %>">Blog</a>
      <a href="/gioi-thieu" class="<%= currentPath === '/gioi-thieu' ? 'is-active' : '' %>">Giới thiệu</a>
      <a href="/lien-he" class="<%= currentPath === '/lien-he' ? 'is-active' : '' %>">Liên hệ</a>
    </nav>

    <div class="nav__actions">
      <form class="search" action="/cua-hang" method="get" role="search">
        <input type="search" name="q" placeholder="Tìm sản phẩm…" aria-label="Tìm sản phẩm" value="<%= typeof q !== 'undefined' ? q : '' %>" />
        <button type="submit" aria-label="Tìm">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        </button>
      </form>

      <% if (user) { %>
        <a class="icon-link" href="<%= user.role === 'admin' ? '/quan-tri' : '/tai-khoan' %>" aria-label="Tài khoản">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        </a>
      <% } else { %>
        <a class="icon-link" href="/tai-khoan/dang-nhap" aria-label="Đăng nhập">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        </a>
      <% } %>

      <a class="icon-link cart-link" href="/gio-hang" aria-label="Giỏ hàng">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 7h13l-1.5 9.5H7.5L6 7Z"/><path d="M6 7 5 4H3"/><circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/></svg>
        <% if (cart.count > 0) { %><span class="cart-badge"><%= cart.count %></span><% } %>
      </a>
    </div>
  </div>
</header>
