<footer class="site-footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a class="brand brand--light" href="/">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 40 40" width="30" height="30"><rect x="3" y="3" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </span>
        <span class="brand__name">DECOR&nbsp;CAR</span>
      </a>
      <p class="footer__tag">Nội thất, decor &amp; trang trí xe hơi — tuyển chọn theo chất liệu và tỉ lệ, cho không gian sống và khoang lái của bạn.</p>
    </div>

    <div class="footer__col">
      <h4>Danh mục</h4>
      <ul>
        <% categories.forEach(function(c){ %>
          <li><a href="/danh-muc/<%= c.slug %>"><%= c.name %></a></li>
        <% }) %>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Hỗ trợ</h4>
      <ul>
        <li><a href="/gioi-thieu">Về chúng tôi</a></li>
        <li><a href="/blog">Blog kinh nghiệm</a></li>
        <li><a href="/lien-he">Liên hệ</a></li>
        <li><a href="/cua-hang">Tất cả sản phẩm</a></li>
        <li><a href="/tai-khoan">Tài khoản của tôi</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Liên hệ</h4>
      <ul class="footer__contact">
        <li><a href="tel:<%= store.phone.replace(/\s/g,'') %>"><%= store.phone %></a></li>
        <li><a href="mailto:<%= store.email %>"><%= store.email %></a></li>
        <li><%= store.address %></li>
      </ul>
    </div>
  </div>

  <div class="container footer__bottom">
    <p>© 2026 DECOR CAR. Mọi quyền được bảo lưu.</p>
    <p>Thiết kế cho không gian sống tinh tế.</p>
  </div>
</footer>
