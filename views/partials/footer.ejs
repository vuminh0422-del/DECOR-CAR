<footer class="site-footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a class="brand brand--light" href="/">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 40 40" width="30" height="30"><rect x="3" y="3" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </span>
        <span class="brand__name">DECOR&nbsp;CAR</span>
      </a>
      <p class="footer__tag">Nội thất, decor &amp; trang trí xe hơi — tuyển chọn theo chất liệu và tỉ lệ, cho không gian sống và khoang lái của bạn.</p>

      <form class="newsletter" action="/dang-ky-nhan-tin" method="post">
        <label for="nl-email">Nhận ưu đãi &amp; mã giảm 10% cho đơn đầu</label>
        <div class="newsletter__row">
          <input id="nl-email" type="email" name="email" placeholder="Email của bạn" aria-label="Email nhận ưu đãi" required />
          <button type="submit" class="btn btn--primary btn--sm">Đăng ký</button>
        </div>
      </form>

      <div class="socials" aria-label="Mạng xã hội">
        <a class="social" href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M14 9h3V6h-3c-2 0-3 1.3-3 3.2V11H8v3h3v6h3v-6h2.6l.4-3H14V9.4C14 9.1 14.3 9 14.6 9H14z"/></svg>
        </a>
        <a class="social" href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a class="social" href="https://tiktok.com" target="_blank" rel="noopener" aria-label="TikTok">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M14 3c.3 2.2 1.6 3.7 3.8 3.9V9.4c-1.4.1-2.7-.3-3.8-1.1v5.6c0 3-2.2 5.1-5 5.1-2.6 0-4.7-1.9-4.7-4.5 0-2.7 2.3-4.7 5.2-4.3v2.6c-.4-.1-.8-.2-1.2-.1-1 .1-1.7.8-1.6 1.9.1 1 .9 1.7 1.9 1.6 1.1 0 1.8-.9 1.8-2.1V3H14z"/></svg>
        </a>
        <a class="social" href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21.6 8.2c-.2-1-.9-1.7-1.9-1.9C17.9 6 12 6 12 6s-5.9 0-7.7.3c-1 .2-1.7.9-1.9 1.9C2 10 2 12 2 12s0 2 .4 3.8c.2 1 .9 1.7 1.9 1.9C6.1 18 12 18 12 18s5.9 0 7.7-.3c1-.2 1.7-.9 1.9-1.9C22 14 22 12 22 12s0-2-.4-3.8zM10 15V9l5 3-5 3z"/></svg>
        </a>
        <a class="social" href="https://zalo.me/<%= store.zalo %>" target="_blank" rel="noopener" aria-label="Zalo">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 5h16v10H9l-5 4V5Z"/><path d="M8 10h8M8 12.5h5"/></svg>
        </a>
      </div>
    </div>

    <div class="footer__col">
      <h4>Danh mục</h4>
      <ul>
        <% categories.forEach(function(c){ %>
          <li><a href="/danh-muc/<%= c.slug %>"><%= c.name %></a></li>
        <% }) %>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Hỗ trợ</h4>
      <ul>
        <li><a href="/gioi-thieu">Về chúng tôi</a></li>
        <li><a href="/blog">Blog kinh nghiệm</a></li>
        <li><a href="/cau-hoi-thuong-gap">Câu hỏi thường gặp</a></li>
        <li><a href="/lien-he">Liên hệ</a></li>
        <li><a href="/tai-khoan">Tài khoản của tôi</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Chính sách</h4>
      <ul>
        <li><a href="/chinh-sach/giao-hang-lap-dat">Giao hàng &amp; lắp đặt</a></li>
        <li><a href="/chinh-sach/bao-hanh">Bảo hành</a></li>
        <li><a href="/chinh-sach/doi-tra">Đổi trả &amp; hoàn tiền</a></li>
        <li><a href="/chinh-sach/huong-dan-mua-hang">Hướng dẫn mua hàng</a></li>
        <li><a href="/chinh-sach/bao-mat">Bảo mật</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Liên hệ</h4>
      <ul class="footer__contact">
        <li><a href="tel:<%= store.phone.replace(/\s/g,'') %>"><%= store.phone %></a></li>
        <li><a href="mailto:<%= store.email %>"><%= store.email %></a></li>
        <li><%= store.address %></li>
      </ul>
    </div>
  </div>

  <div class="container footer__bottom">
    <p>© 2026 DECOR CAR. Mọi quyền được bảo lưu.</p>
    <p>Thiết kế cho không gian sống tinh tế.</p>
  </div>
</footer>
