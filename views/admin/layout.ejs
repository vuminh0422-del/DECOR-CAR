<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin.css" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="admin">
  <aside class="admin-side">
    <a class="admin-brand" href="/quan-tri">
      <svg viewBox="0 0 40 40" width="26" height="26"><rect x="3" y="3" width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      <span>DECOR CAR</span>
    </a>
    <nav class="admin-nav">
      <a href="/quan-tri" class="<%= currentPath === '/quan-tri' ? 'is-active' : '' %>">Tổng quan</a>
      <a href="/quan-tri/san-pham" class="<%= currentPath.indexOf('/quan-tri/san-pham')===0 ? 'is-active' : '' %>">Sản phẩm</a>
      <a href="/quan-tri/don-hang" class="<%= currentPath.indexOf('/quan-tri/don-hang')===0 ? 'is-active' : '' %>">Đơn hàng</a>
      <a href="/quan-tri/khuyen-mai" class="<%= currentPath.indexOf('/quan-tri/khuyen-mai')===0 ? 'is-active' : '' %>">Mã giảm giá</a>
      <a href="/quan-tri/danh-gia" class="<%= currentPath.indexOf('/quan-tri/danh-gia')===0 ? 'is-active' : '' %>">Đánh giá</a>
    </nav>
    <div class="admin-side__foot">
      <a href="/" target="_blank" rel="noopener">Xem cửa hàng ↗</a>
      <form action="/tai-khoan/dang-xuat" method="post"><button type="submit">Đăng xuất</button></form>
    </div>
  </aside>

  <div class="admin-main">
    <header class="admin-top">
      <h1 class="admin-top__title"><%= title.split('—')[0].trim() %></h1>
      <span class="admin-top__user"><%= user.name %></span>
    </header>

    <% if (flash) { %>
      <div class="admin-flash admin-flash--<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <div class="admin-content">
      <%- body %>
    </div>
  </div>
</body>
</html>
