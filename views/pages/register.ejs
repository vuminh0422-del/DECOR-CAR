<section class="section auth-section">
  <div class="container">
    <div class="auth-card frame">
      <p class="eyebrow">Tham gia DECOR CAR</p>
      <h1 class="auth-card__title">Tạo tài khoản</h1>
      <form action="/tai-khoan/dang-ky" method="post" novalidate>
        <div class="field <%= errors.name ? 'has-error' : '' %>">
          <label for="name">Họ và tên</label>
          <input id="name" name="name" value="<%= form.name || '' %>" autocomplete="name" required />
          <% if (errors.name) { %><p class="field__err"><%= errors.name %></p><% } %>
        </div>
        <div class="field <%= errors.email ? 'has-error' : '' %>">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" value="<%= form.email || '' %>" autocomplete="email" required />
          <% if (errors.email) { %><p class="field__err"><%= errors.email %></p><% } %>
        </div>
        <div class="field <%= errors.password ? 'has-error' : '' %>">
          <label for="password">Mật khẩu</label>
          <div class="pw" data-pw>
            <input id="password" name="password" type="password" autocomplete="new-password" minlength="6" required />
            <button type="button" class="pw__toggle" aria-label="Hiện mật khẩu">Hiện</button>
          </div>
          <% if (errors.password) { %><p class="field__err"><%= errors.password %></p><% } else { %><p class="field__hint">Tối thiểu 6 ký tự.</p><% } %>
        </div>
        <button type="submit" class="btn btn--primary btn--block">Tạo tài khoản</button>
      </form>
      <p class="auth-alt">Đã có tài khoản? <a href="/tai-khoan/dang-nhap">Đăng nhập</a></p>
    </div>
  </div>
</section>
