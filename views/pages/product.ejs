<section class="page-head page-head--slim">
  <div class="container">
    <nav class="crumbs" aria-label="breadcrumb">
      <a href="/">Trang chủ</a><span>/</span>
      <% if (category) { %><a href="/danh-muc/<%= category.slug %>"><%= category.name %></a><span>/</span><% } %>
      <span><%= product.name %></span>
    </nav>
  </div>
</section>

<section class="section section--tight">
  <div class="container product-detail">
    <div class="gallery" data-gallery>
      <div class="gallery__main frame frame--lg">
        <img src="<%= product.images[0] %>" alt="<%= product.name %>" id="galleryMain" width="800" height="1000" />
      </div>
      <% if (product.images.length > 1) { %>
        <div class="gallery__thumbs">
          <% product.images.forEach(function(img, i){ %>
            <button type="button" class="gallery__thumb frame <%= i===0?'is-active':'' %>" data-src="<%= img %>" aria-label="Ảnh <%= i+1 %>">
              <img src="<%= img %>" alt="" width="160" height="200" loading="lazy" />
            </button>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="product-info" data-viewed-product="<%= product.id %>">
      <% if (category) { %><p class="eyebrow"><%= category.name %></p><% } %>
      <h1 class="product-info__title"><%= product.name %></h1>

      <% if (rating.count > 0) { %>
        <a href="#danh-gia" class="rating-inline">
          <span class="stars" aria-hidden="true"><%= starString(rating.average) %></span>
          <span class="rating-inline__num"><%= rating.average %></span>
          <span class="rating-inline__count">(<%= rating.count %> đánh giá)</span>
        </a>
      <% } %>

      <div class="product-info__price">
        <span class="price price--lg"><%= formatVND(product.price) %></span>
        <% if (product.compareAt && product.compareAt > product.price) { %>
          <span class="price price--old"><%= formatVND(product.compareAt) %></span>
          <span class="save-tag">Tiết kiệm <%= formatVND(product.compareAt - product.price) %></span>
        <% } %>
      </div>

      <p class="product-info__desc"><%= product.description %></p>

      <ul class="spec">
        <li><span>Mã sản phẩm</span><b><%= product.sku %></b></li>
        <li><span>Tình trạng</span><b><%= product.stock > 0 ? 'Còn hàng' : 'Liên hệ' %></b></li>
        <li><span>Danh mục</span><b><%= category ? category.name : '—' %></b></li>
        <li>
          <span>Tương thích</span>
          <b>
            <% if (product.universalFit) { %>Mọi dòng xe
            <% } else if (product.brands && product.brands.length) { %><%= product.brands.map(function(s){ return brandName(s); }).join(', ') %>
            <% } else { %>Liên hệ tư vấn theo xe<% } %>
          </b>
        </li>
      </ul>

      <form action="/gio-hang/them" method="post" class="buy-form">
        <input type="hidden" name="productId" value="<%= product.id %>" />

        <% if (product.options && product.options.length) { %>
          <div class="product-options">
            <% product.options.forEach(function(o){ %>
              <div class="opt-group">
                <span class="opt-group__label"><%= o.name %></span>
                <div class="opt-pills">
                  <% o.values.forEach(function(v, i){ %>
                    <label class="opt-pill">
                      <input type="radio" name="opt[<%= o.name %>]" value="<%= v %>" <%= i===0?'checked':'' %> />
                      <span><%= v %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <div class="buy">
          <div class="qty" data-qty>
            <button type="button" class="qty__btn" data-step="-1" aria-label="Giảm">−</button>
            <input type="number" name="quantity" value="1" min="1" max="<%= Math.max(1, product.stock) %>" aria-label="Số lượng" />
            <button type="button" class="qty__btn" data-step="1" aria-label="Tăng">+</button>
          </div>
          <div class="buy__actions">
            <button type="submit" class="btn btn--line">Thêm vào giỏ</button>
            <button type="submit" name="buyNow" value="1" class="btn btn--primary">Mua ngay</button>
          </div>
        </div>
      </form>

      <button type="button" class="wish-btn" data-wish="<%= product.id %>" aria-pressed="false">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 20s-7-4.35-9.5-8.5C1 8 2.5 5 5.5 5c2 0 3.2 1.2 4 2.3C10.3 6.2 11.5 5 13.5 5c3 0 4.5 3 3 6.5C19 15.65 12 20 12 20z"/></svg>
        <span class="wish-btn__label">Lưu vào yêu thích</span>
      </button>

      <div class="assurance">
        <span>✓ Giao &amp; lắp đặt tận nơi</span>
        <span>✓ Bảo hành chính hãng</span>
        <span>✓ Tư vấn miễn phí</span>
      </div>
    </div>
  </div>
</section>

<% if (typeof addOns !== 'undefined' && addOns.length) { %>
<section class="section section--tight addons">
  <div class="container">
    <div class="section__head"><p class="eyebrow">Hoàn thiện khoang lái</p><h2 class="section__title section__title--sm">Phụ kiện nên mua kèm</h2></div>
    <div class="addon-grid">
      <% addOns.forEach(function(a){ %>
        <div class="addon">
          <a class="addon__media frame" href="/san-pham/<%= a.slug %>">
            <img src="<%= a.images[0] %>" alt="<%= a.name %>" loading="lazy" width="400" height="500" />
          </a>
          <div class="addon__body">
            <h3 class="addon__name"><a href="/san-pham/<%= a.slug %>"><%= a.name %></a></h3>
            <span class="price"><%= formatVND(a.price) %></span>
            <form action="/gio-hang/them" method="post" class="addon__add">
              <input type="hidden" name="productId" value="<%= a.id %>" />
              <button type="submit" class="btn btn--ghost btn--sm">+ Thêm vào giỏ</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section section--tight" id="danh-gia">
  <div class="container">
    <div class="reviews">
      <div class="reviews__head">
        <p class="eyebrow">Phản hồi khách hàng</p>
        <h2 class="section__title">Đánh giá sản phẩm</h2>
        <% if (rating.count > 0) { %>
          <div class="reviews__score">
            <b><%= rating.average %></b>
            <span class="stars" aria-hidden="true"><%= starString(rating.average) %></span>
            <span><%= rating.count %> lượt đánh giá</span>
          </div>
        <% } %>
      </div>

      <div class="reviews__body">
        <div class="reviews__list">
          <% if (reviewSent) { %>
            <div class="form-alert form-alert--success" role="status">Cảm ơn bạn đã đánh giá!</div>
          <% } %>
          <% if (reviews.length === 0) { %>
            <p class="reviews__empty">Chưa có đánh giá nào. Hãy là người đầu tiên chia sẻ cảm nhận!</p>
          <% } else { %>
            <% reviews.forEach(function(r){ %>
              <article class="review">
                <div class="review__top">
                  <b class="review__name"><%= r.name %></b>
                  <span class="stars stars--sm" aria-label="<%= r.rating %> trên 5 sao"><%= starString(r.rating) %></span>
                </div>
                <p class="review__comment"><%= r.comment %></p>
                <time class="review__date"><%= new Date(r.createdAt).toLocaleDateString('vi-VN') %></time>
              </article>
            <% }) %>
          <% } %>
        </div>

        <aside class="review-form frame">
          <h3>Viết đánh giá</h3>
          <form action="/san-pham/<%= product.slug %>/danh-gia" method="post">
            <div class="field">
              <label for="rv-name">Tên của bạn</label>
              <input id="rv-name" name="name" placeholder="Ví dụ: Anh Minh" />
            </div>
            <div class="field">
              <label>Chấm điểm</label>
              <div class="star-input" data-star-input>
                <% for (var s=5; s>=1; s--){ %>
                  <input type="radio" id="star<%= s %>" name="rating" value="<%= s %>" <%= s===5?'checked':'' %> />
                  <label for="star<%= s %>" aria-label="<%= s %> sao">★</label>
                <% } %>
              </div>
            </div>
            <div class="field">
              <label for="rv-comment">Nhận xét</label>
              <textarea id="rv-comment" name="comment" rows="3" placeholder="Chất lượng, lắp đặt, độ bền…" required></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--block">Gửi đánh giá</button>
          </form>
        </aside>
      </div>
    </div>
  </div>
</section>

<% if (related.length) { %>
<section class="section section--tight">
  <div class="container">
    <div class="section__head"><p class="eyebrow">Gợi ý</p><h2 class="section__title">Sản phẩm liên quan</h2></div>
    <div class="product-grid">
      <% related.forEach(function(p){ %>
        <%- include('../partials/product-card', { product: p }) %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section section--tight" data-recent-section data-recent-exclude="<%= product.id %>" hidden>
  <div class="container">
    <div class="section__head"><p class="eyebrow">Bạn vừa xem</p><h2 class="section__title section__title--sm">Sản phẩm đã xem</h2></div>
    <div class="product-grid" data-recent-root></div>
  </div>
</section>

<!-- Thanh mua nhanh dính đáy màn hình (chỉ hiện trên mobile) -->
<div class="buybar" data-buybar>
  <div class="buybar__info">
    <span class="buybar__name"><%= product.name %></span>
    <span class="buybar__price"><%= formatVND(product.price) %></span>
  </div>
  <form action="/gio-hang/them" method="post" class="buybar__form">
    <input type="hidden" name="productId" value="<%= product.id %>" />
    <button type="submit" class="btn btn--primary btn--sm" <%= product.stock === 0 ? 'disabled' : '' %>>
      <%= product.stock === 0 ? 'Liên hệ' : 'Thêm vào giỏ' %>
    </button>
  </form>
</div>

<script type="application/ld+json">
<%- JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  sku: product.sku,
  category: category ? category.name : undefined,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'VND',
    price: product.price,
    availability: product.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock'
  },
  aggregateRating: rating.count > 0 ? {
    '@type': 'AggregateRating',
    ratingValue: rating.average,
    reviewCount: rating.count
  } : undefined,
  review: (reviews || []).slice(0, 5).map(function(r){
    return {
      '@type': 'Review',
      author: { '@type': 'Person', name: r.name },
      reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
      reviewBody: r.comment
    };
  })
}) %>
</script>

<script type="application/ld+json">
<%- JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: siteUrl + '/' },
    category ? { '@type': 'ListItem', position: 2, name: category.name, item: siteUrl + '/danh-muc/' + category.slug } : null,
    { '@type': 'ListItem', position: category ? 3 : 2, name: product.name, item: canonical }
  ].filter(Boolean)
}) %>
</script>
