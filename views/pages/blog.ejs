<section class="page-head">
  <div class="container">
    <nav class="crumbs"><a href="/">Trang chủ</a><span>/</span><span>Blog</span></nav>
    <p class="eyebrow">Kiến thức &amp; kinh nghiệm</p>
    <h1 class="page-title">Blog DECOR CAR</h1>
    <p class="page-desc">Mẹo độ xe, kinh nghiệm chọn nội thất và chăm sóc khoang lái — chia theo từng nhóm sản phẩm để bạn dễ tìm.</p>
  </div>
</section>

<div class="container"><%- include('../partials/blog-nav', { activeCat: null }) %></div>

<% if (groups.length === 0) { %>
  <section class="section section--tight"><div class="container">
    <div class="empty"><h3>Chưa có bài viết</h3><p>Nội dung sẽ sớm được cập nhật.</p></div>
  </div></section>
<% } else { %>
  <% groups.forEach(function(g){ %>
    <section class="section section--tight blog-section">
      <div class="container">
        <div class="section__head section__head--row">
          <div>
            <p class="eyebrow"><%= g.cat.name %></p>
            <h2 class="section__title section__title--sm"><%= g.cat.desc %></h2>
          </div>
          <div class="blog-section__links">
            <a class="link-more" href="/blog/chuyen-muc/<%= g.cat.slug %>">Tất cả bài <%= g.cat.name %> →</a>
            <a class="link-more link-more--soft" href="/danh-muc/<%= g.cat.productCat %>">Mua sản phẩm →</a>
          </div>
        </div>
        <div class="blog-grid">
          <% g.posts.forEach(function(post){ %>
            <%- include('../partials/blog-card', { post: post }) %>
          <% }) %>
        </div>
      </div>
    </section>
  <% }) %>
<% } %>
