# Sao chép file này thành .env và điền giá trị thật
# cp .env.example .env

# Cổng chạy server (Hostinger VPS thường dùng reverse proxy Nginx -> cổng này)
PORT=3000

# URL gốc của website khi deploy (dùng cho canonical, sitemap.xml, thẻ Open Graph).
# Để trống khi chạy local — hệ thống tự lấy theo host của request.
# SITE_URL=https://decorcar.vn

# Chuỗi bí mật để ký session cookie — ĐỔI thành chuỗi ngẫu nhiên dài khi deploy
SESSION_SECRET=doi-chuoi-nay-thanh-mot-gia-tri-ngau-nhien-that-dai

# Tài khoản quản trị khởi tạo (lần seed đầu tiên)
ADMIN_EMAIL=admin@decorcar.vn
ADMIN_PASSWORD=DecorCar@2026

# Thông tin cửa hàng (hiển thị toàn site)
STORE_PHONE=0900 000 000
STORE_ZALO=0900000000
STORE_EMAIL=lienhe@decorcar.vn
STORE_ADDRESS=123 Đường Trang Trí, Quận 1, TP. Hồ Chí Minh

# Thông tin chuyển khoản (hiển thị ở bước thanh toán)
BANK_NAME=Vietcombank
BANK_ACCOUNT=0123456789
BANK_HOLDER=CUA HANG DECOR CAR

# Google Analytics 4 — để trống nếu chưa dùng. Điền mã đo lường (G-XXXXXXX) để bật theo dõi.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# NODE_ENV=production  # bật khi deploy thật
